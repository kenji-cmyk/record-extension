{
  "name": "browser-wide-audio-recording",
  "version": "1.0.0",
  "description": "Chrome extension for browser-wide audio recording with microphone integration",
  "scripts": {
    "build": "tsc && node build.js",
    "build:ts": "tsc",
    "build:copy": "node build.js",
    "watch": "tsc --watch",
    "clean": "rimraf dist",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --run --coverage"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/jsdom": "^27.0.0",
    "@vitest/ui": "^4.0.18",
    "fast-check": "^4.5.3",
    "jsdom": "^28.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "private": true
}
